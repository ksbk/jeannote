{
  // CSS browser-compatibility warnings from VS Code's built-in CSS language
  // service use MDN data that lags behind real browser support. Properties
  // like text-size-adjust and scrollbar-width are intentional progressive-
  // enhancement patterns paired with vendor-prefixed fallbacks. Without a
  // standalone CSS linter in this project, disabling built-in CSS validation
  // avoids noise while losing nothing — ruff/pre-commit covers the Python
  // side and the CSS is not authored by tooling that would introduce errors.
  "css.validate": false,

  // Pin to the project venv so Pylance never picks up Homebrew or system Python.
  "python.defaultInterpreterPath": "${workspaceFolder}/.venv/bin/python",

  "python.analysis.typeCheckingMode": "basic",
  "python.analysis.useLibraryCodeForTypes": false,
  // Exclude the virtualenv from Pylance analysis — it is not project code.
  // Without this, Django internal type errors in .venv surface in the Problems
  // panel and obscure real issues in the actual codebase.
  // Includes the Pylance default patterns so they are not lost when this array
  // overrides the built-in defaults.
  "python.analysis.exclude": [
    "**/.git",
    "**/.hg",
    "**/.svn",
    "**/.venv",
    "**/.trunk",
    "**/__pycache__",
    "**/node_modules",
    "**/.*"
  ],
  // .trunk/ contains vendored linter test fixtures, many intentionally invalid.
  // Exclude from file watching, search, and explorer to prevent editor noise.
  // The first three entries restore VS Code's default excludes so they are not
  // lost when this object overrides the built-in defaults.
  "files.exclude": {
    "**/.*": true,
    "**/__pycache__": true,
    "**/node_modules": true,
    ".trunk": true
  },
  "search.exclude": {
    "**/.*": true,
    "**/__pycache__": true,
    "**/node_modules": true,
    ".trunk/**": true
  },
  "files.watcherExclude": {
    "**/.trunk/**": true,
    "**/__pycache__/**": true,
    "**/node_modules/**": true,
    "**/.git/objects/**": true,
    "**/.git/subtree-cache/**": true
  },
  "python.analysis.diagnosticSeverityOverrides": {
    "reportMissingModuleSource": "none",
    "reportUnknownMemberType": "none",
    "reportUnknownVariableType": "none",
    "reportUnknownArgumentType": "none",
    "reportUnknownParameterType": "none",
    "reportMissingTypeArgument": "none",
    "reportMissingParameterType": "none",
    "reportConstantRedefinition": "none",
    "reportUnnecessaryTypeIgnoreComment": "none"
  }
}
